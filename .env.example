# 外部系统凭据模板。复制为 .env 后填入真实值；不要提交 .env。

# 飞书开放平台应用，用于读取/写入库存表、报价模板、项目资料夹。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_TENANT_ACCESS_TOKEN=
FEISHU_APP_TOKEN=
FEISHU_INVENTORY_TABLE_ID=
FEISHU_INVENTORY_VIEW_ID=
FEISHU_WRITABLE_APP_TOKEN=
FEISHU_WRITABLE_TABLE_ID=
FEISHU_WRITABLE_TABLE_NAME=
FEISHU_QUOTE_TEMPLATE_FILE_TOKEN=
FEISHU_PROJECT_FOLDER_TOKEN=

# 通义千问 / DashScope，用于图纸文字理解、资料归类、长文档摘要等可审计辅助任务。
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus

# 运行边界。
ALLOW_EXTERNAL_UPLOAD=false
ALLOW_LLM_DOCUMENT_ANALYSIS=false
